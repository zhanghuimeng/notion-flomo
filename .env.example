# Notion 配置
# 1. 前往 https://www.notion.so/my-integrations 创建一个集成
# 2. 复制 Internal Integration Token
NOTION_TOKEN=

# Notion 数据库页面 ID 或 URL
# 例如: https://www.notion.so/your-workspace/xxx?pvs=4
# 或者直接是页面 ID: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NOTION_PAGE=

# Flomo 授权 Token
# 获取方式: 登录 flomo 网页版 -> F12 打开开发者工具 -> Network -> 找到请求头中的 authorization 值
# 格式为: Bearer xxxxx|xxxxx (需要包含 "Bearer " 前缀)
FLOMO_TOKEN=

# 可选配置
# 是否全量更新 (true/false)
FULL_UPDATE=false
# 更新间隔天数
UPDATE_INTERVAL_DAY=7
